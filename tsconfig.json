{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    // Make `@` map directly to `src/`
    "baseUrl": ".",
    "paths": {
     "@/*":    ["src/*"],       // still points at everything
    "@ui/*":  ["src/app/components/*"]  // “ui” maps to src/components
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.{ts,tsx,js,jsx}",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
