datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enum for roles
enum Role {
  user
  admin
}

// Books Model
model Book {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  author          String    @db.VarChar(255)
  description     String?   @db.Text
  file_name       String?   @db.VarChar(255)
  file_url        String?   @db.VarChar(512)
  upload_date     DateTime? @default(now()) // Retain upload date if desired
  cover_url       String?   @db.VarChar(512)
  genres          String[]  // Allows multiple genres per book
  publicationYear Int?      // The year the book was published
  language        String?   // The language of the book
  updatedAt       DateTime  @default(now()) @updatedAt
  metadata        Json?     // For any extra metadata captured from the original text file
  isDeleted       Boolean   @default(false)

  // Relations
  activityLogs     ActivityLog[]
  reviews          Review[]
  readingItems     ReadingListItem[]
  readingPositions ReadingPosition[]
  bookInteractions BookInteraction[]

  @@index([title])
  @@index([author])
  @@index([upload_date])
  @@index([publicationYear])
  @@index([language])
  @@map("books")
}

// Users Model
model User {
  id               Int      @id @default(autoincrement())
  username         String
  displayName      String?  // Optional display name for personalization
  email            String   @unique
  password_hash    String?
  profileImage     Bytes?   // Stores user's profile image binary data directly in the DB
  bio              String?  // A short biography about the user
  socialMediaLinks Json?    // JSON field for storing social media links, e.g. { "twitter": "...", "linkedin": "..." }
  role             Role     @default(user)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relations
  activityLogs     ActivityLog[]
  reviews          Review[]
  readingLists     ReadingList[]
  readingPositions ReadingPosition[]

  @@map("users")
}

// Activity Logs Model
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  bookId    Int?
  timestamp DateTime @default(now())
  details   String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book? @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// Book Reviews Model
model Review {
  id        Int      @id @default(autoincrement())
  bookId    Int
  userId    Int?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// User Reading Lists Model
model ReadingList {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReadingListItem[]

  @@map("reading_lists")
}

// Join Table for Many-to-Many (Reading Lists <-> Books)
model ReadingListItem {
  id            Int      @id @default(autoincrement())
  readingListId Int
  bookId        Int
  order         Int?
  addedAt       DateTime @default(now())

  readingList ReadingList @relation(fields: [readingListId], references: [id], onDelete: Cascade)
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([readingListId, bookId])
  @@map("reading_list_items")
}

// Reading Position Model (Bookmark)
model ReadingPosition {
  id        Int      @id @default(autoincrement())
  userId    Int
  bookId    Int
  position  Int
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("reading_positions")
}

/// New ─ Tracking book downloads & reads
model BookInteraction {
  id        Int              @id @default(autoincrement())
  bookId    Int
  type      InteractionType
  sessionId String?          @db.VarChar(64)     // hashed cookie or “anon”
  createdAt DateTime         @default(now())

  book      Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, type])
  @@index([createdAt])
  @@map("book_interactions")
}

enum InteractionType {
  DOWNLOAD
  READ_START
  READ_FINISH
}
