// prisma/schema.prisma

// Explicit output path to avoid Prisma 7.0 deprecation warning
generator client {
  provider = "prisma-client-js"
  output = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// Enum for roles
enum Role {
  user
  admin
}

/// Store one‑time tokens for “forgot password” flows
model PasswordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// Books Model
model Book {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  author          String    @db.VarChar(255)
  description     String?   @db.Text
  file_name       String?   @db.VarChar(255)
  file_url        String?   @db.VarChar(512)
  pdf_url         String?   @db.VarChar(512)
  txt_url         String?   @db.VarChar(512)
  upload_date     DateTime? @default(now())
  cover_url       String?   @db.VarChar(512)
  genres          String[]
  publicationYear Int?
  language        String?
  updatedAt       DateTime  @default(now()) @updatedAt
  metadata        Json?
  isDeleted       Boolean   @default(false)

  activityLogs     ActivityLog[]
  reviews          Review[]
  readingItems     ReadingListItem[]
  readingPositions ReadingPosition[]
  bookInteractions BookInteraction[]

  @@index([title])
  @@index([author])
  @@index([upload_date])
  @@index([publicationYear])
  @@index([language])
  @@map("books")
}

// Enum for gender
enum Gender {
  MALE
  FEMALE
  OTHER
}

// Users Model
model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  displayName      String?
  email            String    @unique
  password_hash    String?
  dateOfBirth      DateTime?
  gender           Gender?
  avatar_url       String?   @db.VarChar(512)
  settings         Json?
  bio              String?
  socialMediaLinks Json?
  role             Role      @default(user)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  activityLogs     ActivityLog[]
  reviews          Review[]
  readingLists     ReadingList[]
  readingPositions ReadingPosition[]
  passwordResets   PasswordReset[]
  
  // Community relations
  topics    Topic[]    @relation("UserTopics")
  comments  Comment[]  @relation("UserComments")

  @@map("users")
}

// Discussion topics
model Topic {
  id         Int       @id @default(autoincrement())
  title      String
  body       String    @db.Text
  createdAt  DateTime  @default(now())

  // who posted it
  author     User      @relation("UserTopics", fields: [authorId], references: [id])
  authorId   Int

  comments   Comment[] @relation("TopicComments")

  @@map("topics")
}

// Comments on topics
model Comment {
  id         Int       @id @default(autoincrement())
  body       String    @db.Text
  createdAt  DateTime  @default(now())

  // relation back to topic
  topic      Topic     @relation("TopicComments", fields: [topicId], references: [id])
  topicId    Int

  // who commented
  author     User      @relation("UserComments", fields: [authorId], references: [id])
  authorId   Int

  @@map("comments")
}

// ActivityLog
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  bookId    Int?
  timestamp DateTime @default(now())
  details   String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book? @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// Review
model Review {
  id        Int      @id @default(autoincrement())
  bookId    Int
  userId    Int?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ReadingList
model ReadingList {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReadingListItem[]

  @@map("reading_lists")
}

model ReadingListItem {
  id            Int      @id @default(autoincrement())
  readingListId Int
  bookId        Int
  order         Int?
  addedAt       DateTime @default(now())

  readingList ReadingList @relation(fields: [readingListId], references: [id], onDelete: Cascade)
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([readingListId, bookId])
  @@map("reading_list_items")
}

model ReadingPosition {
  id        Int      @id @default(autoincrement())
  userId    Int
  bookId    Int
  position  Int
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("reading_positions")
}

model BookInteraction {
  id        Int             @id @default(autoincrement())
  bookId    Int
  type      InteractionType
  sessionId String?         @db.VarChar(64)
  createdAt DateTime        @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, type])
  @@index([createdAt])
  @@map("book_interactions")
}

enum InteractionType {
  DOWNLOAD
  READ_START
  READ_FINISH
  EXTRACT
  REVIEW
}
